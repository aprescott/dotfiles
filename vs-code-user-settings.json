{
    "telemetry.telemetryLevel": "off",
    "settingsSync.keybindingsPerPlatform": false,

    "workbench.activityBar.location": "top",

    // "security.workspace.trust.banner": "untilDismissed",
    "security.workspace.trust.banner": "never",

    "editor.mouseWheelScrollSensitivity": 2,
    "editor.scrollBeyondLastLine": false,
    "editor.padding.bottom": 50,
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": true,
    "workbench.tree.enableStickyScroll": true,
    "accessibility.dimUnfocused.enabled": true,
    "accessibility.dimUnfocused.opacity": 0.9,
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "editor.snippetSuggestions": "top",

    "editor.linkedEditing": true,

    "window.newWindowDimensions": "maximized",
    "workbench.startupEditor": "newUntitledFile",

    "workbench.localHistory.maxFileEntries": 200,

    "workbench.editor.decorations.badges": true,
    "workbench.editor.decorations.colors": true,

    "workbench.editor.highlightModifiedTabs": true,
    "workbench.settings.openDefaultSettings": true,
    "workbench.settings.useSplitJSON": true,
    "workbench.settings.openDefaultKeybindings": true,

    "workbench.editor.enablePreviewFromQuickOpen": false,

    // much more pleasant rapid x'ing
    "workbench.editor.tabSizing": "fixed",

    "terminal.integrated.inheritEnv": false,

    "editor.inlineSuggest.fontFamily": "Monaspace Neon Var, monospace",
    // "editor.fontLigatures": "'calt', 'liga', 'dlig', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08'",
    // "editor.fontFamily": "'Monaspace Neon Var', Menlo, Monaco, 'Courier New', monospace",
    // "editor.fontVariations": "'wght' 300",

    "editor.cursorBlinking": "phase",
    "editor.cursorStyle": "line-thin",

    "workbench.colorTheme": "GitHub Dark Default",

    "workbench.colorCustomizations": {
        "[GitHub Dark Default]": {
            "activityBarBadge.background": "#78242b",
            "badge.background": "#78242b",
            "focusBorder": "#78242b",
            "progressBar.background": "#78242b",
            "statusBar.focusBorder": "#78242b80",
            "statusBarItem.focusBorder": "#78242b",

            "editorCursor.foreground": "#ff00aa",

            "editorBracketMatch.background": "#3fb95040",
            "editorBracketMatch.border": "#3fb95010",

            "editorWhitespace.foreground": "#f0c2b990",

            "editor.lineHighlightBackground": "#22262e",

            // Ctrl/Cmd + F highlights.
            "editor.findMatchHighlightBackground": "#d6b03f60",

            "editor.selectionBackground": "#78242b",
            "editor.inactiveSelectionBackground": "#600b18e0",
            // When text is selected, this is the non-selected matching content.
            "editor.selectionHighlightBackground": "#520e16f0",
            "editor.selectionHighlightBorder": "#78242b40",

            // Instances of _words_ under the cursor.
            "editor.wordHighlightBackground": "#00000000",
            "editor.wordHighlightTextBackground": "#00000000",
            "editor.wordHighlightStrongBackground": "#00000000",
            "editor.wordHighlightBorder": "#81717199",
            "editor.wordHighlightStrongBorder": "#81717199",
            "editor.wordHighlightTextBorder": "#81717199",
            // Unchanged:
            // "editor.symbolHighlightBackground"
            // "editor.symbolHighlightBorder"

            "editorOverviewRuler.selectionHighlightForeground": "#78242b20",
        },
    },

    "editor.tokenColorCustomizations": {
        "[GitHub Dark Default]": {
            "comments": "#9e8f8d",
            "textMateRules": [
                {
                    "scope": "comment",
                    "settings": {
                        "fontStyle": "italic",
                    },
                },
            ],
        },
    },

    "files.autoSave": "onFocusChange",
    "files.eol": "\n",
    "files.trimFinalNewlines": true,
    "files.insertFinalNewline": true,

    "files.trimTrailingWhitespace": true,
    "trailing-spaces.highlightCurrentLine": false,
    "editor.minimap.autohide": "none",
    "editor.minimap.scale": 2,
    "editor.minimap.showSlider": "always",

    "editor.guides.bracketPairs": true,
    "editor.rulers": [80, 120],
    "rewrap.wrappingColumn": 80,
    "rewrap.autoWrap.enabled": true,

    "editor.columnSelection": false,
    "editor.wordWrap": "off",
    "editor.wrappingIndent": "same",
    "editor.renderWhitespace": "selection",

    "editor.formatOnPaste": true,
    "editor.codeActionsOnSave": {
        // "source.organizeImports": "always",
        // "source.addMissingImports": "always",
    },

    "diffEditor.ignoreTrimWhitespace": false,

    "search.searchEditor.defaultNumberOfContextLines": 2,
    "search.showLineNumbers": true,
    "search.searchEditor.reusePriorSearchConfiguration": true,

    "[css]": {
        "editor.tabSize": 2,
    },
    "[erb]": {
        "editor.tabSize": 2,
    },
    "[html]": {
        "editor.tabSize": 2,
        "rewrap.autoWrap.enabled": false,
    },
    "[ini]": {
        "rewrap.autoWrap.enabled": false,
    },
    "[javascript]": {
        "editor.tabSize": 2,
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file",
    },
    "[ruby]": {
        "editor.tabSize": 2,
        "editor.formatOnSave": false,
    },
    "[rust]": {
        "editor.formatOnSave": true,
    },
    "[scss]": {
        "editor.tabSize": 2,
    },

    "byesig.opacity": 0.75,
    "byesig.showIcon": false,
    "byesig.fold": false,
    "solargraph.hover": false,
    // ruby extension handles formatting
    "solargraph.autoformat": false,
    "solargraph.formatting": false,
    "solargraph.references": false,
    "rubyLsp.formatter": "auto",
    "rubyLsp.enabledFeatures": {
        "inlayHint": false,
    },
    "rubyLsp.featuresConfiguration": {
        "codeLens": {
            "gemfileLinks": false,
        },
    },
    "rubyLsp.featureFlags": {
        "launcher": false,
    },

    "tailwind-fold.autoFold": false,

    "editor.inlineSuggest.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": true,
        "html": true,
    },
    "chat.requestQueuing.defaultAction": "queue",
    "chat.experimental.incrementalRendering.enabled": true,
    "chat.experimental.incrementalRendering.animationStyle": "blur",
    "github.copilot.nextEditSuggestions.enabled": true,
    "python.languageServer": "Pylance",
    "workbench.browser.enableChatTools": true,
    "git.autofetch": true,
    "editor.minimap.size": "fit",
    "chat.tools.urls.autoApprove": {
        "https://code.visualstudio.com": true,
        "https://github.com/microsoft/vscode/wiki/*": true,
        "https://developer.mozilla.org/en-US/docs": true,
        "https://drafts.csswg.org": true,
        "https://stackoverflow.com/questions": true,
    },
    // Don't use the VS Code specific profile.
    "powershell.enableProfileLoading": false,
    // Don't show the extension terminal. Integrated is fine.
    "powershell.integratedConsole.startInBackground": true,
    "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
    "github.copilot.chat.localIndex.enabled": true,

    "terminal.integrated.autoReplies": {
        "Terminate batch job (Y/N)": "Y\r"
    }
}
