# Prompt variable:
OLD_PROMPT="$PROMPT"

# bash will interpret `\033` but zsh needs an escape character.
ESC=$'\033'

setopt PROMPT_SUBST

# Arbitrary RGB (decimal): "%{\033[38;2;R;G;Bm%}"
# Not supported everywhere.
function prompt_rgb() {
  # Check if all arguments are provided
  if [ "$#" -ne 3 ]; then
    echo "Error: Function prompt_rgb_code() requires three arguments (R, G, B)"
    return 1
  fi

  # Check if arguments are integers between 0 and 255
  for i in "$@"; do
    if ! [[ "$i" =~ ^[0-9]+$ ]]; then
      echo "Error: All arguments must be integers between 0 and 255"
      return 1
    elif [ "$i" -lt 0 ] || [ "$i" -gt 255 ]; then
      echo "Error: All arguments must be integers between 0 and 255"
      return 1
    fi
  done

  local R="$1"
  local G="$2"
  local B="$3"
  local escape_sequence="%{${ESC}[38;2;${R};${G};${B}m%}"

  echo "${escape_sequence}"
}

RESET_STYLE="%{${ESC}[00m%}"
BOLD_ON="%{${ESC}[1m%}"
FAINT_ON="%{${ESC}[3m%}" # maps to italics

YELLOW="%{${ESC}[0;33m%}"
YELLOW_BOLD="%{${ESC}[1;33m%}"
RED_BOLD="%{${ESC}[1;31m%}"
LIGHT_ORANGE="%{${ESC}[38;5;215m%}"
DARK_ORANGE="%{${ESC}[38;5;130m%}"
CUSTOM_ORANGE="$(prompt_rgb 220 165 50)"

# 90 = "bright black" / "dark gray"
PROMPT_STYLE="${RESET_STYLE}%{${ESC}[0;90m%}"
ERROR_STYLE="$RED_BOLD"

PROMPT_GIT_BRANCH_COLOR_PART_1="${LIGHT_ORANGE}"
PROMPT_GIT_BRANCH_COLOR_PART_2="${LIGHT_ORANGE}"

# we might not have git completion available, so squealch the missing
# command error.
if ! command -v __git_ps1 > /dev/null; then
  function __git_ps1 {
    echo > /dev/null
  }
fi

function prompt_git_branch_part() {
  local branch=$(__git_ps1 '%s')

  if [ -z "$branch" ]; then
    echo -n # nothing
  elif [[ $branch =~ ([^/]+/)(.*) ]]; then
    # separator included this way so that it's never made bold
    if [ "$1" -eq "1" ]; then echo -n "::"; fi

    echo "${match[$1]}"
  else
    # separator included this way so that it's never made bold
    if [ "$1" -eq "1" ]; then echo -n "::"; fi

    # bundle everything into the 2nd part, leaving earlier parts blank
    if [ "$1" -eq "2" ]; then echo -e "$branch"; fi
  fi
}

# https://sw.kovidgoyal.net/kitty/text-sizing-protocol/
KITTY_TEXT_SIZING="%{${ESC}]66;n=3:d=4:h=1:v=2;%}"
KITTY_TEXT_SIZING_END="%{${ESC}"$'\a'"%}"

# If 5+ parts, show the first part, then ellipsis, then the last 3.
#
# https://unix.stackexchange.com/questions/273529/shorten-path-in-zsh-prompt
#
PROMPT_DIR_PATH="%(5~|%-1~/…/%3~|%4~)"
#PROMPT_TERMINATOR="$"
PROMPT_TERMINATOR="❯"
PROMPT_TERMINATOR="${KITTY_TEXT_SIZING}${PROMPT_TERMINATOR}${KITTY_TEXT_SIZING_END}"

function precmd() {
  export LAST_EXIT_CODE=$?
}

PROMPT=""
PROMPT="${PROMPT}${PROMPT_STYLE}${PROMPT_DIR_PATH}"
PROMPT="${PROMPT}${PROMPT_GIT_BRANCH_COLOR_PART_1}\$(prompt_git_branch_part 1)${PROMPT_GIT_BRANCH_COLOR_PART_2}\$(prompt_git_branch_part 2)"
PROMPT="${PROMPT}${PROMPT_STYLE}\$(if [ \$LAST_EXIT_CODE -gt 0 ]; then echo -e '$ERROR_STYLE'; fi)${PROMPT_TERMINATOR}$RESET_STYLE "
